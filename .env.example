# TINHLE AI — Environment Variables Template
# Copy this to .env for local development
# NEVER commit .env to git

# Gmail SMTP (for /send-report endpoint)
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Google Earth Engine
GEE_PROJECT=tinhle-ai

# Location Configuration
LOCATION_NAME=Ruwa
LOCATION_LAT=-17.8875
LOCATION_LON=31.2444
LOCATION_TIMEZONE=Africa/Harare

# Community Report Google Sheet URL
COMMUNITY_SHEET_URL=https://docs.google.com/spreadsheets/d/101wlyOmjbchCJuhvFVT5SPq89OILTpj_z2AWXGaUCd4/export?format=csv

# Set automatically by Railway in production — do not set manually there
# PORT=8000
